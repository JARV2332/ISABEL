{
  "redirects": [
    {
      "source": "/",
      "destination": "/ISABEL",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/ISABEL/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
