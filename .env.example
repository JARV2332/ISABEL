# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role solo en servidor (n8n o API routes)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — respuestas conversacionales de ISA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs — voz de ISA
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── n8n (orquestador) ───────────────────────────────────────────
# URL base SIN /webhook al final. Ejemplo: https://tu-nombre.app.n8n.cloud
N8N_WEBHOOK_BASE_URL=

# Opcional: autenticación del webhook n8n
# N8N_API_KEY=

# ─── Sign-Speak (avatar video + reconocimiento de señas) ─────────
# Obtener en: https://sign-speak.com — NUNCA exponer al navegador
# SIGN_SPEAK_API_KEY=
