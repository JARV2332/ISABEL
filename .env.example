# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ElevenLabs (futuro)
# ELEVENLABS_API_KEY=

# OpenAI (futuro)
# OPENAI_API_KEY=

# ─── n8n (orquestador) ───────────────────────────────────────────
# URL base SIN /webhook al final. Ejemplo: https://tu-nombre.app.n8n.cloud
N8N_WEBHOOK_BASE_URL=

# Opcional: autenticación del webhook n8n
# N8N_API_KEY=

# ─── Sign-Speak (avatar video + reconocimiento de señas) ─────────
# Obtener en: https://sign-speak.com — NUNCA exponer al navegador
# SIGN_SPEAK_API_KEY=
