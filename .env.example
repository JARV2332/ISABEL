# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Opcional: clave publishable nueva de Supabase (sb_publishable_...)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role solo si prefieres insertar sin políticas RLS públicas
SUPABASE_SERVICE_ROLE_KEY=

# IA de ISA — Groq (gratis, prioridad) u OpenAI
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Visión (pizarra / señas): meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ElevenLabs — voz de ISA
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── n8n (orquestador) ───────────────────────────────────────────
# URL base SIN /webhook al final. Ejemplo: https://tu-nombre.app.n8n.cloud
N8N_WEBHOOK_BASE_URL=

# Opcional: autenticación del webhook n8n
# N8N_API_KEY=

# ─── Sign-Speak (avatar video + reconocimiento de señas) ─────────
# Obtener en: https://sign-speak.com — NUNCA exponer al navegador
# SIGN_SPEAK_API_KEY=
