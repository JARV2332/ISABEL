{
  "name": "ISABEL - IoT simulado",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "iot",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-iot",
      "name": "Webhook IoT",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [260, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"output\": \"Acción IoT: \" + ($json.data.action || 'ping'),\n  \"device\": {\n    \"connected\": true,\n    \"led\": $json.data.action === 'emergency' ? 'red' : ($json.data.action === 'light-on' ? 'yellow' : 'green'),\n    \"message\": \"Dispositivo ISABEL respondió vía n8n\"\n  }\n}",
        "options": {}
      },
      "id": "respond-iot",
      "name": "Respuesta IoT",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [520, 300]
    }
  ],
  "connections": {
    "Webhook IoT": {
      "main": [[{ "node": "Respuesta IoT", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
